            <Button
    Content="🔄 Atualizar Abas"
    Width="150"
    Height="30"
    Margin="0,0,0,10"
    Click="BtnAtualizarAbas_Click"/>
            <DataGrid x:Name="dgAbas"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          RowBackground="White"
          AlternatingRowBackground="#F9F9F9"
          Margin="10">

                <DataGrid.Columns>

                    <!-- Título -->
                    <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="180" IsReadOnly="True"/>

                    <!-- URL -->
                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="220" IsReadOnly="True"/>

                    <!-- Tipo: Menor / Maior -->
                    <DataGridTemplateColumn Header="Tipo" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding TipoLance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsEnabled="{Binding Monitorando, Converter={StaticResource InverseBool}}">
                                    <System:String>Menor</System:String>
                                    <System:String>Maior</System:String>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Valor Mínimo -->
                    <DataGridTemplateColumn Header="Mín" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ValorMinimo, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=LostFocus}" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ValorMinimo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding Monitorando, Converter={StaticResource InverseBool}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Valor Máximo -->
                    <DataGridTemplateColumn Header="Máx" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ValorMaximo, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=LostFocus}" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ValorMaximo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding Monitorando, Converter={StaticResource InverseBool}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Incremento -->
                    <DataGridTemplateColumn Header="Incremento" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Incremento, Mode=TwoWay, StringFormat=N2, UpdateSourceTrigger=LostFocus}" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Incremento, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding Monitorando, Converter={StaticResource InverseBool}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status -->
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130" IsReadOnly="True"/>

                    <!-- Botão Iniciar / Parar -->
                    <DataGridTemplateColumn Header="Automação" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Width="90" Height="26"
                            Click="BtnAutomacao_Click"
                            Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Content" Value="▶ Iniciar"/>
                                            <Setter Property="Background" Value="#4CAF50"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitorando}" Value="True">
                                                    <Setter Property="Content" Value="⏹ Parar"/>
                                                    <Setter Property="Background" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

                <!-- Colorir linha por status -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EstouEmPrimeiro}" Value="True">
                                <Setter Property="Background" Value="LightGreen"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EstouEmPrimeiro}" Value="False">
                                <Setter Property="Background" Value="#FFB6B6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="LIMITE ATINGIDO">
                                <Setter Property="Background" Value="#FFE082"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

            </DataGrid>

        </StackPanel>
        
    </Grid>
</Window>
